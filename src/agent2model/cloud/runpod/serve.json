{
  "name": "agent2model-serve",
  "description": "Serve a compiled model behind an OpenAI-compatible vLLM endpoint.",
  "imageName": "runpod/pytorch:2.3.0-py3.11-cuda12.1.1-devel-ubuntu22.04",
  "gpuTypeId": "NVIDIA A100 80GB PCIe",
  "gpuCount": 1,
  "cloudType": "SECURE",
  "containerDiskInGb": 60,
  "volumeInGb": 100,
  "volumeMountPath": "/workspace",
  "ports": "8000/http",
  "env": {
    "AGENT2MODEL_BUILD_DIR": "/workspace/build/travel",
    "AGENT2MODEL_PORT": "8000",
    "HF_HOME": "/workspace/hf"
  },
  "dockerArgs": "bash -lc 'cd /workspace && bash setup.sh serve'"
}
